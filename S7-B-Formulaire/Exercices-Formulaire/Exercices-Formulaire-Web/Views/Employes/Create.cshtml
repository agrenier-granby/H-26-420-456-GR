@model Exercices_Formulaire_Web.ViewModels.EmployeCreateVM

@{
    ViewData["Title"] = "Créer un employé";
}

<h1>Créer un employé</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Nom" class="control-label"></label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Age" class="control-label"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DateNaissance" class="control-label"></label>
                <input asp-for="DateNaissance" class="form-control" type="date" />
                <span asp-validation-for="DateNaissance" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DateEmbauche" class="control-label"></label>
                <input asp-for="DateEmbauche" class="form-control" type="date" />
                <span asp-validation-for="DateEmbauche" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SalaireAnnuel" class="control-label"></label>
                <input asp-for="SalaireAnnuel" class="form-control" />
                <span asp-validation-for="SalaireAnnuel" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Titre" class="form-label"></label>
                <select asp-for="Titre" asp-items="@Html.GetEnumSelectList<Exercices_Formulaire_Web.Models.Titre>()" class="form-select">
                    <option value="">Choisissez un titre</option>
                </select>
                <span asp-validation-for="Titre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Statut" class="form-label"></label>
                <select asp-for="Statut" asp-items="@Html.GetEnumSelectList<Exercices_Formulaire_Web.Models.StatutEmploye>()" class="form-select">
                    <option selected="selected" value="">Choisissez un statut</option>
                </select>
                <span asp-validation-for="Statut" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TypeRemuneration" class="form-label"></label>
                <select asp-for="TypeRemuneration" asp-items="@Html.GetEnumSelectList<Exercices_Formulaire_Web.Models.TypeRemuneration>()" class="form-select"></select>
                <span asp-validation-for="TypeRemuneration" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PaysId" class="control-label"></label>
                <select asp-for="PaysId" asp-items="Model.ListePays" class="form-control"></select>
                <span asp-validation-for="PaysId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DepartementId" class="control-label"></label>
                <select asp-for="DepartementId" asp-items="Model.ListeDepartements" class="form-control">
                    <option value="">Choisissez une équipe</option>
                </select>
                <span asp-validation-for="DepartementId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Créer" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Retour à la liste</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
