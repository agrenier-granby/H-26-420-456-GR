@model EmployeEditVM

@{
    ViewData["Title"] = "Édition";
}

<h1>Édition</h1>

<h4>Édition d'un employé</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Employe.EmployeId" />
            <div class="form-group">
                <label asp-for="Employe.Nom" class="control-label"></label>
                <input asp-for="Employe.Nom" class="form-control" />
                <span asp-validation-for="Employe.Nom" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employe.Age" class="control-label"></label>
                <input asp-for="Employe.Age" class="form-control" />
                <span asp-validation-for="Employe.Age" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employe.DateEmbauche" class="control-label"></label>
                <input asp-for="Employe.DateEmbauche" type="date" class="form-control" />
                <span asp-validation-for="Employe.DateEmbauche" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employe.Salaire" class="control-label"></label>
                <input asp-for="Employe.Salaire" class="form-control" />
                <span asp-validation-for="Employe.Salaire" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Employe.EstEnEmploi" /> @Html.DisplayNameFor(model => model.Employe.EstEnEmploi)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="Employe.PaysId" class="control-label"></label>
                <!--<input asp-for="PaysId" class="form-control" />-->
                @Html.DropDownListFor(m => m.Employe.PaysId, new SelectList(Model.Pays, "PaysId", "Nom"), "Choisir un pays", new { @class = "form-control" })
                <!-- Utilisation du Tag Helper -->
                <!--<select asp-for="PaysId" asp-items="Model.PaysSLI" class="form-control"></select>-->
                <span asp-validation-for="Employe.PaysId" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="Employe.DepartementId" class="control-label"></label>

                @Html.DropDownListFor(m => m.Employe.DepartementId, new SelectList(Model.Departements, "DepartementId", "Nom"), "Choisir un département", new { @class = "form-control" })
                <span asp-validation-for="Employe.DepartementId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Enregistrer" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" asp-controller="Home">Retour</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
